# Local development (copy to .env and fill in values)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=lunch_app
DB_SSL=false

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:64733
PORT=3001

# TEXTGURU SMS (optional for local dev)
TEXTGURU_USERNAME=
TEXTGURU_PASSWORD=
TEXTGURU_SENDER_ID=
TEXTGURU_DLT_TEMP_ID=
